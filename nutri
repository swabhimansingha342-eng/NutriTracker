// ─── MAIN APP ─────────────────────────────────────────────────────────────────
export default function NutriTrack() {
  const [loggedIn, setLoggedIn] = useState(false);
  const [screen, setScreen] = useState("home");

  const mainScreens = ["home", "scanner", "meals", "water", "profile"];
  const isMainScreen = mainScreens.includes(screen);

  if (!loggedIn) {
    return (
      <div style={{ maxWidth: 430, margin: "0 auto", minHeight: "100vh" }}>
        <style>{globalStyles}</style>
        <LoginScreen onLogin={() => setLoggedIn(true)} />
      </div>
    );
  }

  const renderScreen = () => {
    switch (screen) {
      case "home": return <HomeScreen setScreen={setScreen} />;
      case "scanner": return <ScannerScreen />;
      case "meals": return <MealsScreen setScreen={setScreen} />;
      case "water": return <WaterScreen />;
      case "profile": return <ProfileScreen setLoggedIn={setLoggedIn} />;
      default: return <ExtraScreens screen={screen} setScreen={setScreen} />;
    }
  };

  return (
    <div style={{ maxWidth: 430, margin: "0 auto", minHeight: "100vh", background: COLORS.bg, position: "relative", overflow: "hidden" }}>
      <style>{globalStyles}</style>
      <TopBar screen={screen} setScreen={setScreen} />
      {renderScreen()}
      <BottomNav screen={screen} setScreen={setScreen} />

      {/* Extra navigation shortcuts */}
      {screen === "home" && (
        <div style={{ position: "fixed", bottom: 80, left: 20, display: "flex", flexDirection: "column", gap: 8, zIndex: 100 }}>
          {[
            { id: "mood", emoji: "😊", label: "Mood" },
            { id: "calories", emoji: "⚡", label: "Activity" },
            { id: "achievements", emoji: "🏆", label: "Awards" },
          ].map(({ id, emoji, label }) => (
            <button key={id} onClick={() => setScreen(id)} style={{
              display: "flex", alignItems: "center", gap: 8, padding: "8px 14px", borderRadius: 99,
              background: "rgba(255,255,255,0.95)", backdropFilter: "blur(10px)",
              border: `1px solid ${COLORS.greyMid}`, cursor: "pointer",
              fontFamily: FONTS.display, fontWeight: 600, fontSize: 12, color: COLORS.text,
              boxShadow: "0 2px 12px rgba(0,0,0,0.1)"
