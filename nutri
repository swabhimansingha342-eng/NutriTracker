          </div>
        </div>
        <ProgressBar value={checkedCount} max={totalItems} height={6} bg="rgba(255,255,255,0.15)" style={{ marginTop: 12 }} />
      </div>

      <div style={{ padding: "20px" }}>
        {categories.map(({ name, emoji, items }, ci) => (
          <div key={name} style={{ marginBottom: 20, animation: `fadeUp 0.4s ${ci * 0.1}s ease both`, opacity: 0, animationFillMode: "forwards" }}>
            <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 10 }}>
