              <span style={{ fontSize: 12, color: COLORS.grey }}>({items.filter(item => checked[`${name}-${item}`]).length}/{items.length})</span>
            </div>
            <Card style={{ padding: "8px 0" }}>
              {items.map((item, ii) => {
                const key = `${name}-${item}`;
                const isChecked = checked[key];
                return (
                  <div key={item} onClick={() => setChecked(c => ({ ...c, [key]: !c[key] }))} style={{
                    display: "flex", alignItems: "center", gap: 14, padding: "12px 18px",
                    borderBottom: ii < items.length - 1 ? `1px solid ${COLORS.greyLight}` : "none", cursor: "pointer"
                  }}>
                    <div style={{
                      width: 24, height: 24, borderRadius: 8, border: `2px solid ${isChecked ? COLORS.green : COLORS.greyMid}`,
                      background: isChecked ? COLORS.green : "transparent", display: "flex", alignItems: "center", justifyContent: "center",
                      flexShrink: 0, transition: "all 0.2s ease"
                    }}>
                      {isChecked && <span style={{ color: "#fff" }}><Icons.Check /></span>}
                    </div>
                    <span style={{ fontSize: 14, color: isChecked ? COLORS.grey : COLORS.text, textDecoration: isChecked ? "line-through" : "none", transition: "all 0.2s ease" }}>{item}</span>
                  </div>
                );
              })}
            </Card>
          </div>
        ))}
      </div>
    </Screen>
  );
};

